# ============================================================================
# Core Settings
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================================
# Database Configuration
# ============================================================================
# Database names (for local PostgreSQL)
AIRFLOW_DB_NAME=zara_airflow
ETL_DB_NAME=zara_etl

# Database connection strings
# For local development (using docker-compose postgres service)
# DATABASE_URL=postgresql://zara_user:zara_password@postgres:5432/zara_etl

# External/Managed Database (Render.com PostgreSQL)
DATABASE_URL=postgresql+psycopg://zara:INGozMDWKnYZrc61IIizSWNN3elzVawS@dpg-d3v1k8je5dus73a1tnng-a.singapore-postgres.render.com/zara_rj6s

# Airflow Database URL (using same host as main database)
# If using separate database for Airflow, create one on Render and update the database name:
AIRFLOW_DATABASE_URL=postgresql+psycopg://zara:INGozMDWKnYZrc61IIizSWNN3elzVawS@dpg-d3v1k8je5dus73a1tnng-a.singapore-postgres.render.com/zara_rj6s

# Skip database creation if using external/managed databases
# Set to true when connecting to pre-existing databases
SKIP_DB_CREATION=true

# ============================================================================
# Airflow Configuration
# ============================================================================
AIRFLOW_UID=50000

# ============================================================================
# arXiv Ingestion - Required
# ============================================================================
ARXIV_MAX_RESULTS=400
ARXIV_MAX_RESULTS_PER_REQUEST=50

# ============================================================================
# arXiv Ingestion - Optional (defaults provided)
# ============================================================================
# Filter by categories (comma-separated). Leave empty or omit to search ALL papers.
# Examples: cs.AI,cs.LG,cs.CL,cs.CV,cs.NE,stat.ML
# ARXIV_CATEGORIES=
# ARXIV_SORT_BY=submittedDate
# ARXIV_SORT_ORDER=descending
# ARXIV_START_INDEX=0
# ARXIV_RATE_LIMIT_SECONDS=3
# ARXIV_MAX_RETRIES=3

# ============================================================================
# Quality Filter - PDF Structure & Readability
# ============================================================================
# QF_PDF_MIN_PAGES=4
# QF_PDF_MAX_PAGES=50
# QF_PDF_MIN_SIZE_KB=100
# QF_PDF_MAX_SIZE_MB=25
# QF_TEXT_MIN_CHARS=1000

# ============================================================================
# Quality Filter - Content Quality
# ============================================================================
# QF_LANGUAGE=en
# QF_ABSTRACT_MIN_WORDS=80
# QF_ABSTRACT_MAX_WORDS=500

# ============================================================================
# Quality Filter - Metadata
# ============================================================================
# QF_PRIORITY_CATEGORIES=astro-ph,physics,cs.AI,cs.LG,q-bio
# QF_EXCLUDE_CATEGORIES=cs.CR
# QF_RECENCY_YEARS=5

# ============================================================================
# Quality Filter - Format Validation
# ============================================================================
# QF_MIN_SECTIONS=3
# QF_MIN_FIGURES=0
# QF_MAX_FIGURES=10

# ============================================================================
# Quality Filter - Processing
# ============================================================================
# QF_BATCH_SIZE=50
# QF_ENABLE_PDF_DOWNLOAD=true

# ============================================================================
# OpenAI API Configuration (REQUIRED for DocETL)
# ============================================================================
# For self-hosted AI (OpenAI-compatible endpoint):
# Note: DocETL uses LiteLLM, so prefix model with "openai/" for custom endpoints
OPENAI_API_KEY=1926675a0297f4d395ca901e4682ed5da63de52ee34211eb5a6e2170f6a41752
OPENAI_API_BASE=https://sunset-plan-speaks-digit.trycloudflare.com/v1
DEFAULT_MODEL=openai/gpt-oss:20b

# ============================================================================
# DocETL Processing - Core Configuration
# ============================================================================
# DOCETL_BATCH_SIZE=10
# DOCETL_ENABLE=true
# DOCETL_MAX_RETRIES=2
# DOCETL_TIMEOUT_SECONDS=300

# ============================================================================
# DocETL Processing - LLM Configuration
# ============================================================================
# Note: For custom endpoints with LiteLLM, prefix model with "openai/"
DOCETL_LLM_PROVIDER=openai
DOCETL_LLM_MODEL=openai/gpt-oss:20b
DOCETL_LLM_JUDGE_MODEL=openai/gpt-oss:20b
# DOCETL_LLM_TEMPERATURE=0.7
# DOCETL_LLM_MAX_TOKENS=4000
# DOCETL_LLM_REQUEST_TIMEOUT=600  # Increase for slow self-hosted models (seconds)

# ============================================================================
# DocETL Processing - Article Generation Settings
# ============================================================================
# DOCETL_MIN_BLOCKS=5
# DOCETL_MAX_BLOCKS=20
# DOCETL_MIN_WORD_COUNT=500
# DOCETL_MAX_WORD_COUNT=2000
# DOCETL_PARAGRAPH_TARGET_WORDS=150

# ============================================================================
# DocETL Processing - Validation Thresholds
# ============================================================================
# DOCETL_MIN_READABILITY_SCORE=7.0
# DOCETL_MIN_ENGAGEMENT_SCORE=7.0
# DOCETL_MIN_ACCURACY_SCORE=9.0
# DOCETL_ENABLE_VALIDATION=true

# ============================================================================
# DocETL Processing - Gleaning (Automatic Retry with Feedback)
# ============================================================================
# Enable gleaning: DocETL will automatically retry failed validations with feedback
# DOCETL_ENABLE_GLEANING=true
# DOCETL_GLEANING_ROUNDS=2
# DOCETL_VALIDATION_PROMPT=  # Optional custom validation prompt

# ============================================================================
# DocETL Processing - PDF Extraction
# ============================================================================
# DOCETL_EXTRACT_FULL_TEXT=true
# DOCETL_EXTRACT_FIGURES=false
# DOCETL_MAX_PDF_SIZE_MB=25
# DOCETL_PDF_DOWNLOAD_TIMEOUT=60

# ============================================================================
# DocETL Processing - Internals
# ============================================================================
# DOCETL_INTERMEDIATE_DIR=storage/docetl_intermediate

# ============================================================================
# Debug Mode
# ============================================================================
DEBUG=true